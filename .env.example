# Discord bot token from the Discord Developer Portal
DISCORD_TOKEN=your_token_here

# Command prefix for legacy (non-slash) commands, if used
COMMAND_PREFIX=!

# SQLAlchemy connection string. Default points at Cascadebot.db in the project root.
DATABASE_URL=sqlite:///Cascadebot.db

# Set to "1" for verbose debug logging
DEBUG=0

# Dev-mode guild command syncing (instant, scoped to one server) vs global
# sync (slower propagation, all servers). Leave DEV_MODE=False for production.
DEV_MODE=False
SERVER_ID=your_dev_server_id_here

# Comma-separated Discord user IDs allowed to run /admin_testgear even in a
# server where they don't have Administrator permission. Optional -- users
# with Administrator in the current server can always use it.
ADMIN_USER_IDS=
